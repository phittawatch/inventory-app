{
  "functions": {
    "api/**/*.php": { "runtime": "vercel-php@0.7.3" }
  },
  "routes": [
    { "src": "/", "dest": "/api/select-storage.php" },
    { "src": "/index", "dest": "/api/index.php" },
    { "src": "/select-storage", "dest": "/api/select-storage.php" },
        { "src": "/dashboard", "dest": "/api/dashboard.php" },
    { "src": "/(.*)", "dest": "/api/$1" }
    ]
}